<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>PUE — Interactive Notebooks</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="font-sans text-gray-800 bg-white p-5">
  <div class="max-w-4xl mx-auto">
    <header class="bg-gray-100 p-6 text-center rounded-lg mb-6">
      <h1 class="text-2xl font-bold mb-2">PUE — Interactive Notebooks</h1>
      <p class="text-sm">marimo notebooks running in your browser via WebAssembly. No installation, no account required.</p>
    </header>

    <main>
      {% if notebooks %}
      <h2 class="text-xl font-bold text-center my-4">Notebooks</h2>
      <p class="text-center mb-4 text-sm text-gray-600">Editable — modify code and re-run cells</p>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-8">
        {% for notebook in notebooks %}
        <div class="bg-gray-50 border border-gray-200 rounded-lg overflow-hidden">
          <div class="bg-gray-200 p-3 font-semibold">{{ notebook.display_name }}</div>
          <div class="p-4 flex flex-wrap gap-2">
            <a href="{{ notebook.html_path }}" class="inline-block bg-blue-500 hover:bg-blue-600 text-white py-1 px-3 rounded transition-colors">Slides</a>
            {% if notebook.scroll_path %}
            <a href="{{ notebook.scroll_path }}" class="inline-block bg-gray-500 hover:bg-gray-600 text-white py-1 px-3 rounded transition-colors">Scroll + Code</a>
            {% endif %}
          </div>
        </div>
        {% endfor %}
      </div>
      {% endif %}

      {% if apps %}
      <h2 class="text-xl font-bold text-center my-4">Apps</h2>
      <p class="text-center mb-4 text-sm text-gray-600">Read-only — code hidden, just the UI</p>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {% for app in apps %}
        <div class="bg-gray-50 border border-gray-200 rounded-lg overflow-hidden">
          <div class="bg-gray-100 p-3 font-semibold">{{ app.display_name }}</div>
          <div class="p-4">
            <a href="{{ app.html_path }}" class="inline-block bg-amber-500 hover:bg-amber-600 text-white py-1 px-3 rounded transition-colors">Open App</a>
          </div>
        </div>
        {% endfor %}
      </div>
      {% endif %}
    </main>

    <footer class="mt-10 pt-6 border-t border-gray-200 text-center text-sm text-gray-600">
      <p>Built with <a href="https://marimo.io" target="_blank" class="text-blue-500 hover:underline">marimo</a></p>
    </footer>
  </div>
</body>
</html>
